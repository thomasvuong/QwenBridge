flowchart TD
    %% ── Input Layer ─────────────────────────────────────────────────────────
    User(["👤 User"])
    MCP["MCP Client\n(Claude Code / Cursor / Windsurf)"]
    REST["REST / WebSocket\n(Web / Mobile)"]
    OpenClaw["OpenClaw Skill\n(SKILL.md)"]

    User --> MCP
    User --> REST
    User --> OpenClaw

    %% ── QwenBridge Core ──────────────────────────────────────────────────────
    subgraph QwenBridge ["🌉 QwenBridge MCP Server (FastAPI + FastMCP)"]
        direction TB
        Orch["🎭 Orchestrator\norchestrator.py"]
        Router["🔀 Model Router\nrouter/model_router.py"]
        AW["🌍 AgentWorld\nPre-flight Simulator"]

        Orch --> Router
        Orch --> AW
    end

    MCP & REST & OpenClaw --> QwenBridge

    %% ── Agent Pool ───────────────────────────────────────────────────────────
    subgraph Agents ["🤖 Agent Pool"]
        direction LR
        MemAgent["🧠 Memory Agent\nmemory_agent.py"]
        ToolAgent["🔧 Tool Agent\ntool_agent.py"]
        VisionAgent["👁️ Multimodal Agent\nmultimodal_agent.py"]
    end

    Orch --> Agents

    %% ── Qwen Model Tier ──────────────────────────────────────────────────────
    subgraph QwenCloud ["☁️ Qwen Cloud (DashScope)"]
        direction LR
        Turbo["qwen-turbo\n$0.05/$0.20/1M"]
        Plus["qwen-plus\n$0.40/$1.20/1M"]
        Max["qwen-max\n$1.60/$6.40/1M"]
        Thinking["qwen3-max-thinking\n$1.20/$6.00/1M"]
        VL["qwen-vl-max\n$0.16/$0.64/1M"]
        Coder["qwen-coder-plus\n$0.30/$1.50/1M"]
    end

    Router --> QwenCloud
    VisionAgent --> VL

    %% ── Alibaba Cloud ────────────────────────────────────────────────────────
    subgraph AlibabaCloud ["🏗️ Alibaba Cloud"]
        TS["Table Store\nPersistent Memory"]
        OSS["OSS\nFile Storage"]
    end

    MemAgent --> TS
    ToolAgent --> OSS

    %% ── AgentWorld ───────────────────────────────────────────────────────────
    subgraph AWModel ["🌍 Qwen-AgentWorld-35B"]
        AWLocal["Local (HuggingFace)\nor API Mode"]
    end

    AW --> AWModel

    %% ── Styling ──────────────────────────────────────────────────────────────
    style QwenBridge fill:#1a1a2e,stroke:#4a9eff,color:#fff
    style Agents     fill:#16213e,stroke:#4a9eff,color:#fff
    style QwenCloud  fill:#0f3460,stroke:#4a9eff,color:#fff
    style AlibabaCloud fill:#e94560,stroke:#ff6b6b,color:#fff
    style AWModel    fill:#533483,stroke:#a855f7,color:#fff
