# QwenBridge — Environment Variables
# Copy to .env and fill in your values

# ── Qwen / DashScope ──────────────────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Alibaba Cloud (for OSS + Table Store) ────────────────────────────────────
ALIBABA_ACCESS_KEY_ID=your-access-key-id
ALIBABA_ACCESS_KEY_SECRET=your-access-key-secret
ALIBABA_REGION=ap-southeast-1
ALIBABA_OSS_BUCKET=qwenbridge-storage
ALIBABA_TABLESTORE_INSTANCE=qwenbridge-memory
ALIBABA_TABLESTORE_ENDPOINT=https://qwenbridge-memory.ap-southeast-1.ots.aliyuncs.com

# ── Qwen-AgentWorld (local or API) ───────────────────────────────────────────
AGENTWORLD_MODE=api           # "local" (HuggingFace) or "api" (OpenAI-compat server)
AGENTWORLD_MODEL=Qwen/Qwen-AgentWorld-35B-A3B
AGENTWORLD_API_URL=http://localhost:8000/v1   # only if mode=local

# ── Server ────────────────────────────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8765
LOG_LEVEL=INFO
